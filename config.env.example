# ==============================================================================
# Website Health Monitoring System - Configuration
# Rename this file to config.env to activate overrides.
# ==============================================================================

# ------------------------------------------------------------------------------
# Thresholds
# ------------------------------------------------------------------------------
# Maximum acceptable ICMP latency in milliseconds before triggering a MEDIUM risk
LATENCY_THRESHOLD_MS=500

# Number of ICMP packets to send during network check
PING_COUNT=3

# Connection timeout for HTTP requests (in seconds)
HTTP_TIMEOUT_SEC=10

# ------------------------------------------------------------------------------
# Security Content Inspection
# ------------------------------------------------------------------------------
# A pipe-separated list of keywords to search for in the HTTP response body
# This is treated as an extended case-insensitive regular expression by grep
SECURITY_KEYWORDS="(sql syntax|exception in thread|root:|fatal error|stack trace|access denied)"

# ------------------------------------------------------------------------------
# Output and Logging
# ------------------------------------------------------------------------------
# Path to store the generated JSON or TXT reports
REPORTS_DIR="reports"

# Path to store the application execution logs
LOGS_DIR="logs"

# Main log file name
LOG_FILE="${LOGS_DIR}/monitor.log"

# ------------------------------------------------------------------------------
# Advanced Settings
# ------------------------------------------------------------------------------
# User-Agent string to use for curl requests
USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/114.0.0.0 Safari/537.36"
